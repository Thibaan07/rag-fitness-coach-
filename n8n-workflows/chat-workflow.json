      ],
      "id": "263f7aa9-c344-4c37-82bd-818a9b861a05",
      "name": "Generate Answer"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst answerText = response.candidates[0].content.parts[0].text;\n\nreturn [{\n  json: {\n    output: answerText\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
