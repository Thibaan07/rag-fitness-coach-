      "id": "d7d9f20b-5c15-411c-8491-d0bc53846abd",
      "name": "Search ChromaDB"
    },
    {
      "parameters": {
        "jsCode": "const question = $('Edit Fields').item.json.question;\nconst docs = $json.documents[0];\n\nconst context = docs.map((doc, i) => `[${i+1}] ${doc}`).join('\\n\\n');\n\nconst prompt = `You are a helpful, friendly fitness coach chatting with someone. Use the context below to answer naturally and conversationally, like a text message reply — not a formal report. Keep it concise. The context may not use the exact same words as the question, so use reasonable judgment to connect related information. Only say you don't have enough information if the context is truly unrelated to the question.\n\n\n\nContext:\n${context}\n\nQuestion: ${question}\n\nAnswer:`;\n\nreturn [{ json: { prompt: prompt } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        0
      ],
      "id": "502d0012-a02f-47bf-9677-1e0c45d8553b",
      "name": "Build Prompt"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash:generateContent?key=YOUR_GEMINI_API_KEY\n",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents: [ { parts: [ { text: $json.prompt } ] } ] }) }}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
